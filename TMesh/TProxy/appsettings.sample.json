{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "TProxy": {
    "MqttAddress": "<your mqtt server address>",
    "MqttPort": 8883,
    "MqttUser": "tproxy",
    "MqttPassword": "<your mqtt password>",
    "MqttAllowUntrustedCertificates": false,
    "MqttUseTls": true,
    "MqttTelegramTopic": "TProxy/prod/telegram/update",
    "MqttStatusTopic": "TBot/prod/status",
    "TelegramWebhookSecret": "<your telegram webhook secret>",
    "DisableTelegramTokenValidation": false,
    "TelegramApiBaseUrl": "",
    "ProxyAuthSecret": "<your proxy auth secret>",
    "ProxyAuthHeader": "X-Api-Key"
  }
}
